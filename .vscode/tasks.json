{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "shell",
      "command": "node esbuild.mjs",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "watch",
      "type": "shell",
      "command": "node esbuild.mjs --watch",
      "isBackground": true,
      "problemMatcher": {
        "owner": "esbuild",
        "pattern": {
          "regexp": "^✘ \\[ERROR\\] (.+)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\[esbuild\\] ビルド開始",
          "endsPattern": "^\\[esbuild\\] ビルド完了"
        }
      },
      "presentation": {
        "reveal": "never"
      }
    }
  ]
}
